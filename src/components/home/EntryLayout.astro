---
import BaseLayout from "@components/base/BaseLayout.astro";
import { markdownify } from "@lib/textConverter";
import Button from "@components/common/Button.astro";
import type { HomeEntry } from "@/types";
import { Image } from "astro:assets";

interface Props {
  entry: HomeEntry;
}

const { entry } = Astro.props;
const { image, imageAlt, title, content, button } = entry.data;
---

<BaseLayout>
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="text-center lg:col-6">
          {
            image && (
              <div class="blur-[0px] flex justify-center">
                <Image
                  class="mb-6 w-96 drop-shadow-[0_0_25px_rgba(0,0,0,0.9)]"
                  src={image}
                  alt={imageAlt}
                  width={1024}
                  height={1024}
                  loading="eager"
                />
              </div>
            )
          }

          <h1
            set:html={markdownify(title)}
            class="mb-6 text-6xl md:text-7xl font-primary tracking-[0.12em] text-[#E2C79D]"
            style="text-shadow: 0 0 6px rgba(0,0,0,0.45);"
          />

    <div class="mb-8 flex flex-col items-center">
  <div class="flex items-center justify-center gap-4">

    <!-- LEFT DECOR -->
    <div class="flex items-center gap-2">
      <span 
        class="h-[2px] w-10 bg-[#E2C79D]/80"
        style="clip-path: polygon(0 50%, 100% 0, 100% 100%);"
      ></span>
      <span class="w-1.5 h-1.5 rotate-45 bg-[#E2C79D]/90"></span>
    </div>

    <!-- TEXT (NO BACKGROUND) -->
    <span
      set:html={markdownify(content)}
      class="text-2xl md:text-3xl text-[#F0D7A8] uppercase whitespace-nowrap"
      style="
        font-family: 'Fondamento', serif;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-shadow:
          0 0 12px rgba(0,0,0,0.95),
          0 2px 6px rgba(0,0,0,0.8),
          0 0 2px rgba(255,220,150,0.25);
      "
    />

    <!-- RIGHT DECOR -->
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rotate-45 bg-[#E2C79D]/90"></span>
      <span 
        class="h-[2px] w-10 bg-[#E2C79D]/80"
        style="clip-path: polygon(0 0, 0 100%, 100% 50%);"
      ></span>
    </div>

  </div>

  {
    button && (
      <div class="mt-8">
        <Button
          label={button.label}
          link={button.link}
          newtab
          hoverInvert
          color=""
        />
      </div>
    )
  }
</div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>