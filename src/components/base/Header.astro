---
import ThemeSwitcher from "@components/base/ThemeSwitcher.astro";
import { IoSearch } from "react-icons/io5";

const { pathname } = Astro.url;

const stickyHeader = true;

const menu = [
  { name: "Home", url: "/" },
  { name: "About", url: "/about" },
  { name: "Characters", url: "/docs" },
  { name: "Storylines", url: "/blog" },
  { name: "Lore", url: "/recipes" },
  { name: "Gallery", url: "/poetry" },
];
---

<header
  transition:persist
  class={`mx-auto max-w-5xl parchment-glass px-6 py-3 z-30 mt-6 rounded-2xl ${stickyHeader && "sticky top-0"}`}
>
  <nav class="relative flex flex-wrap items-center justify-between">
    <input id="nav-toggle" type="checkbox" class="hidden" />

    <label
      for="nav-toggle"
      class="order-0 flex cursor-pointer items-center text-[#2B2118] md:hidden lg:order-1"
    >
      <svg id="show-button" class="block h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
      <svg id="hide-button" class="hidden h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"
        ></polygon>
      </svg>
    </label>

    <ul
      id="nav-menu"
      class="order-3 hidden w-full pb-6 text-center md:order-1 md:flex md:w-auto md:space-x-2 md:pb-0 lg:space-x-4 lg:text-left"
    >
      {
        menu.map((item) => (
          <li>
            <a
              href={item.url}
              class={`block p-2 font-primary text-xl font-semibold tracking-[0.06em] transition lg:px-4 lg:py-3 ${
                pathname === `${item.url}/` || pathname === item.url
                  ? "text-[#F5E7C8]"
                  : "text-[#D6B98A] hover:text-[#E2C79D]"
              }`}
              style="text-shadow: 0 0 4px rgba(0,0,0,0.3); opacity: 1;"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="order-1 ml-auto flex items-center md:order-2 lg:ml-0">
      <a
        class="mr-4 inline-block text-xl text-[#3A2C20] transition hover:text-[#2B2118]"
        href="/search"
        aria-label="search"
      >
        <IoSearch />
      </a>
      <ThemeSwitcher />
    </div>
  </nav>
</header>